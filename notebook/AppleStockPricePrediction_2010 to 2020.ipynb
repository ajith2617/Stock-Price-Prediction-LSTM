   "source": [
    "# 1. Data Loading and Initial Exploration\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from statsmodels.tsa.stattools import adfuller\n",
    "df = pd.read_csv("data/Apple Stock Price.csv")\n",
    "df_model = df.copy()\n",
    "\n",
    "# 2. Data Cleaning and Transformation\n",
    "df_model.rename(columns = {\"Date\" : \"Date\",\n",
    "                           \" Close/Last\" : \"Close\",\n",
    "                           \" Volume\" : \"Volume\",\n",
    "                           \" Open\" : \"Open\",\n",
    "                           \" High\" : \"High\",\n",
    "                           \" Low\" : \"Low\"}, inplace = True)\n",
    "# Replace and Change DataType\n",
    "col = [\"Close\",\"Open\",\"High\",\"Low\"]\n",
    "df_model[col] = df_model[col].replace(r\"[$]\",\"\",regex =True).astype(float)\n",
    "df_model[\"Volume\"] = df_model[\"Volume\"].astype(int)\n",
    "\n",
    "# 3. Exploratory Data Analysis (EDA)\n",
    "df_model = df_model[['Date','Open','High','Low','Close','Volume']]\n",
    "df_model[\"Date\"] = pd.to_datetime(df_model[\"Date\"], format = \"mixed\")\n",
    "df_model = df_model.sort_values(\"Date\").reset_index(drop = True)\n",
    "duplicates = df_model.duplicated().sum()\n",
    "print(\"Duplicate Rows:\", duplicates)\n",
    "\n",
    "# Null Check\n",
    "print(df_model.info())\n",
    "print(df_model.describe())\n",
    "print(df_model.isnull().sum())\n",
    "null_percentage = (df_model.isnull().sum() / len(df_model)) * 100\n",
    "\n",
    "# 4. Outlier Detection Using IQR\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "df_model[\"Return\"] = df_model[\"Close\"].pct_change()\n",
    "Q1 = df_model[\"Return\"].quantile(0.25)\n",
    "Q3 = df_model[\"Return\"].quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR\n",
    "outlier = df_model[(df_model[\"Return\"] < lower) | (df_model[\"Return\"] > upper)]\n",
    "#outlier.sort_values(\"Return\").head(10)\n",
    "#outlier.sort_values(\"Return\", ascending = False).head(10)\n",
    "\n",
    "# 5. Rolling Statistics Analysis\n",
    "rolling_mean = df_model[\"Close\"].rolling(30).mean()\n",
    "rolling_std = df_model[\"Close\"].rolling(30).std()\n",
    "\n",
    "# 6. Stationarity Testing (ADF Test)\n",
    "result_return = adfuller(df_model[\"Close\"].dropna())\n",
    "print(\"Return ADF Statistic:\", result_return[0])\n",
    "print(\"Return p-value:\", result_return[1])\n",
    "\n",
    "#7. Data Preprocessing and Feature Scaling\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "train_end = int(len(df_model) * 0.7)\n",
    "scaler = MinMaxScaler()\n",
    "train_data = df_model[[\"Close\"]][:train_end]\n",
    "scaler.fit(train_data)\n",
    "scaled_data = scaler.transform(df_model[['Close']])\n",
    "\n",
    "# 8. Sliding Window Creation\n",
    "X = []\n",
    "y = []\n",
    "for i in range(60, len(scaled_data)):\n",
    "    X.append(scaled_data[i-60:i])\n",
    "    y.append(scaled_data[i])\n",
    "\n",
    "import numpy as np\n",
    "X = np.array(X)\n",
    "y = np.array(y)\n",
    "print(\"X Shape:\", X.shape)\n",
    "print(\"y Shape:\", y.shape)\n",
    "\n",
    "'''70% Train\n",
    "   15% Validation\n",
    "   15% Test'''\n",
    "\n",
    "# 9. LSTM Model Development\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import LSTM\n",
    "from tensorflow.keras.layers import Dense\n",
    "from tensorflow.keras.layers import Dropout\n",
    "\n",
    "tf.random.set_seed(42)\n",
    "np.random.seed(42)\n",
    "model = Sequential()\n",
    "model.add(LSTM(50,\n",
    "               return_sequences = True,\n",
    "               input_shape = (60,1)))\n",
    "\n",
    "model.add(Dropout(0.2))\n",
    "model.add(LSTM(50))\n",
    "model.add(Dropout(0.2))\n",
    "model.add(Dense(1))\n",
    "\n",
    "model.compile(optimizer = \"adam\",\n",
    "              loss = \"mse\")\n",
    "\n",
    "# 10. Model Training and Validation\n",
    "train_size = int(len(X) * 0.7)\n",
    "val_size = int(len(X) * 0.15)\n",
    "X_train = X[:train_size]\n",
    "X_val = X[train_size : train_size + val_size]\n",
    "X_test = X[train_size + val_size :]\n",
    "\n",
    "y_train = y[:train_size]\n",
    "y_val = y[train_size : train_size + val_size]\n",
    "y_test = y[train_size + val_size :]\n",
    "\n",
    "# Training\n",
    "history = model.fit(\n",
    "    X_train,\n",
    "    y_train,\n",
    "    epochs=50,\n",
    "    batch_size=32,\n",
    "    validation_data=(X_val,y_val)\n",
    ")\n",
    "\n",
    "# 11. LSTM Prediction and Evaluation\n",
    "y_pred_lstm = model.predict(X_test)\n",
    "\n",
    "#Inverse Scaling\n",
    "y_pred_lstm = scaler.inverse_transform(y_pred_lstm)\n",
    "y_test_lstm = scaler.inverse_transform(y_test.reshape(-1,1))\n",
    "\n",
    "# Model Evaluation\n",
    "# MAE\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "mae = mean_absolute_error(y_test_lstm, y_pred_lstm)\n",
    "# RMSE and MSE\n",
    "from sklearn.metrics import mean_squared_error\n",
    "#import numpy as np\n",
    "mse = mean_squared_error(y_test_lstm,y_pred_lstm)\n",
    "rmse = np.sqrt(mse)\n",
    "# MAPE\n",
    "mape = np.mean(np.abs((y_test_lstm - y_pred_lstm) / y_test_lstm) * 100)\n",
    "\n",
    "# 12. Baseline Model Comparison (Naive Forecast)\n",
    "y_test_naive = pd.Series(y_test_lstm.flatten())\n",
    "y_pred_naive = y_test_naive.shift(1)\n",
    "\n",
    "# Baseline Model Comparison and Evaluation\n",
    "# Remove NaN line\n",
    "y_test_naive = y_test_naive[1:]\n",
    "y_pred_naive = y_pred_naive[1:]\n",
    "# MAE\n",
    "naive_mae = mean_absolute_error(y_test_naive, y_pred_naive)\n",
    "# MSE and RMSE\n",
    "naive_mse = mean_squared_error(y_test_naive, y_pred_naive)\n",
    "naive_rmse = np.sqrt(naive_mse)\n",
    "# MAPE\n",
    "naive_mape = np.mean(np.abs((y_test_naive - y_pred_naive) / y_test_naive) * 100)\n",
    "\n",
    "# 13. Model Performance Comparison and Visualization\n",
    "# LSTM plot\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.title(\"LSTM Forecast Plot\")\n",
    "plt.plot(y_test_lstm, label=\"Actual\")\n",
    "plt.plot(y_pred_lstm, label=\"Predicted\")\n",
    "plt.legend()\n",
    "plt.show()\n",
    "\n",
    "# Navie Plot\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.title(\"Naive Forecast Plot\")\n",
    "plt.plot(y_test_naive, label=\"Actual\")\n",
    "plt.plot(y_pred_naive, label=\"Predicted\")\n",
    "plt.legend()\n",
    "plt.show()\n",
    "\n",
    "# 14. Comparison\n",
    "comparison = pd.DataFrame({\n",
    "    \"Model\":[\"LSTM\",\"Naive\"],\n",
    "    \"MAE\":[mae,naive_mae],\n",
    "    \"RMSE\":[rmse,naive_rmse],\n",
    "    \"MAPE\":[mape,naive_mape]\n",
    "})\n",
    "\n",
    "print(\"Model Comparison/n\",comparison)\n",
    "\n",
    "# 15. Predictions\n",
    "# Predict Next Day Closing using LSTM\n",
    "Last_60_days = scaled_data[-60:]\n",
    "X_next = np.array(Last_60_days)\n",
    "X_next = X_next.reshape(1,60,1)\n",
    "next_day_scaled = model.predict(X_next)\n",
    "next_day_price = scaler.inverse_transform(next_day_scaled)\n",
    "\n",
    "# Predict Next Day Closing using Naive\n",
    "naive_next_day_price = df_model[\"Close\"].iloc[-1]\n",
    "\n",
    "predictions_comparison = pd.DataFrame({\"Model\":[\"LSTM Prediction\",\"Naive Prediction\"],\n",
    "                           \"Predicted Price\" :[next_day_price[0][0],naive_next_day_price]})\n",
    "print(\"Model Predictions/n\",predictions_comparison)"
   ]
  },
